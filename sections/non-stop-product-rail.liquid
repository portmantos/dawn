{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- assign rail_collection = section.settings.collection -%}
{%- if rail_collection == blank -%}
  {%- assign rail_collection = collections.all -%}
{%- endif -%}
{%- assign rail_link = section.settings.button_link | default: rail_collection.url -%}

<section class="non-stop-product-rail color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="non-stop-section-heading non-stop-section-heading--split">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="non-stop-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.text != blank -%}
        <div class="non-stop-section-heading__text rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    {%- if rail_collection != blank and rail_collection.products_count > 0 -%}
      <ul class="grid product-grid non-stop-product-rail__grid" role="list">
        {%- assign skip_card_product_styles = false -%}
        {%- for product in rail_collection.products limit: section.settings.products_to_show -%}
          <li class="grid__item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'portrait',
              image_shape: 'default',
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              skip_styles: skip_card_product_styles,
              quick_add: 'none',
              section_id: section.id
            %}
          </li>
          {%- assign skip_card_product_styles = true -%}
        {%- endfor -%}
      </ul>
    {%- else -%}
      <div class="non-stop-empty-state">
        <p>{{ section.settings.empty_text | escape }}</p>
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div class="non-stop-section-action">
        <a class="button button--secondary" href="{{ rail_link | default: routes.all_products_collection_url }}">
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Non-Stop product rail",
  "tag": "section",
  "class": "section-non-stop-product-rail",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Product collection" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Start here" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The pieces that go everywhere." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>A considered lineup of carry-ons, checked bags, and travel essentials.</p>" },
    { "type": "range", "id": "products_to_show", "min": 4, "max": 8, "step": 1, "label": "Products to show", "default": 4 },
    { "type": "checkbox", "id": "show_secondary_image", "label": "Show second image on hover", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop all luggage" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "empty_text", "label": "Empty state text", "default": "Select a collection in the theme editor to feature products here." },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [
    { "name": "Non-Stop product rail" }
  ]
}
{% endschema %}
