<section
  class="non-stop-hero non-stop-hero--{{ section.settings.content_position }} color-{{ section.settings.color_scheme }}"
  style="--non-stop-hero-overlay: {{ section.settings.image_overlay | divided_by: 100.0 }};"
>
  <div class="non-stop-hero__media" aria-hidden="true">
    {%- if section.settings.image != blank -%}
      <picture>
        {%- if section.settings.mobile_image != blank -%}
          <source media="(max-width: 749px)" srcset="{{ section.settings.mobile_image | image_url: width: 1200 }}">
        {%- endif -%}
        <img
          src="{{ section.settings.image | image_url: width: 2400 }}"
          alt="{{ section.settings.image.alt | escape }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          fetchpriority="high"
        >
      </picture>
    {%- else -%}
      <div class="non-stop-hero__placeholder"><span>NON-STOP</span></div>
    {%- endif -%}
  </div>
  <div class="non-stop-hero__veil"></div>

  <div class="non-stop-hero__inner page-width">
    <div class="non-stop-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="non-stop-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1>{{ section.settings.heading | escape }}</h1>
      {%- if section.settings.text != blank -%}
        <div class="non-stop-hero__text rte">{{ section.settings.text }}</div>
      {%- endif -%}
      <div class="non-stop-hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a class="button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_button_label != blank -%}
          <a class="non-stop-text-link" href="{{ section.settings.secondary_button_link | default: routes.all_products_collection_url }}">
            {{ section.settings.secondary_button_label | escape }}
            <span aria-hidden="true">↗</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Non-Stop hero",
  "tag": "section",
  "class": "section-non-stop-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Travel, without the drag."
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Built for every way you go."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Thoughtful luggage for the quick getaway, the long haul, and everything in between.</p>"
    },
    {
      "type": "range",
      "id": "image_overlay",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image overlay",
      "default": 35
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop luggage"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary link label",
      "default": "See the collections"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    }
  ],
  "presets": [
    {
      "name": "Non-Stop hero"
    }
  ]
}
{% endschema %}
