<section class="non-stop-collection-showcase color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="non-stop-section-heading">
      {%- if section.settings.eyebrow != blank -%}
        <p class="non-stop-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="non-stop-section-heading__text rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="non-stop-collection-showcase__grid">
      {%- for block in section.blocks -%}
        {%- assign card_collection = block.settings.collection -%}
        {%- assign card_image = block.settings.image -%}
        {%- if card_image == blank and card_collection != blank and card_collection.image != blank -%}
          {%- assign card_image = card_collection.image -%}
        {%- endif -%}
        {%- assign card_title = block.settings.title -%}
        {%- if card_title == blank and card_collection != blank -%}
          {%- assign card_title = card_collection.title -%}
        {%- endif -%}
        {%- assign card_url = block.settings.link -%}
        {%- if card_collection != blank -%}
          {%- assign card_url = card_collection.url -%}
        {%- endif -%}

        <a
          class="non-stop-collection-card"
          href="{{ card_url | default: routes.all_products_collection_url }}"
          {{ block.shopify_attributes }}
        >
          <div class="non-stop-collection-card__media">
            {%- if card_image != blank -%}
              <img
                src="{{ card_image | image_url: width: 1400 }}"
                alt="{{ card_image.alt | default: card_title | escape }}"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="non-stop-collection-card__placeholder" aria-hidden="true">
                <span>{{ card_title | default: 'Collection' | escape }}</span>
              </div>
            {%- endif -%}
          </div>
          <div class="non-stop-collection-card__veil"></div>
          <div class="non-stop-collection-card__content">
            {%- if block.settings.eyebrow != blank -%}
              <p class="non-stop-eyebrow">{{ block.settings.eyebrow | escape }}</p>
            {%- endif -%}
            <h3>{{ card_title | default: 'Collection' | escape }}</h3>
            {%- if block.settings.text != blank -%}
              <div class="rte">{{ block.settings.text }}</div>
            {%- endif -%}
            <span class="non-stop-card-link">
              {{ block.settings.button_label | default: 'Explore collection' | escape }}
              <span aria-hidden="true">↗</span>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Non-Stop collection showcase",
  "tag": "section",
  "class": "section-non-stop-collection-showcase",
  "max_blocks": 2,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Two ways to travel"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your kind of ready."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>One collection for the everyday trip. One for the trips that ask a little more of you.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Card image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The everyday edit" },
        { "type": "text", "id": "title", "label": "Title", "default": "The Core Collection" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Clean, dependable pieces for the trips already on your calendar.</p>" },
        { "type": "text", "id": "button_label", "label": "Link label", "default": "Shop the collection" },
        { "type": "url", "id": "link", "label": "Fallback link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Non-Stop collection showcase",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}
