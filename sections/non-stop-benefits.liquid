<section class="non-stop-benefits color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="non-stop-benefits__heading">
        <h2>{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}
    <div class="non-stop-benefits__grid">
      {%- for block in section.blocks -%}
        <div class="non-stop-benefit" {{ block.shopify_attributes }}>
          <span class="non-stop-benefit__icon">
            {% render 'non-stop-travel-icon', name: block.settings.icon %}
          </span>
          <div>
            <h3>{{ block.settings.title | escape }}</h3>
            {%- if block.settings.text != blank -%}
              <div class="rte">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.non_stop_benefits.name",
  "tag": "section",
  "class": "section-non-stop-benefits",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.non_stop_benefits.heading_label", "default": "t:sections.non_stop_benefits.heading_default" },
    { "type": "color_scheme", "id": "color_scheme", "label": "t:sections.non_stop_benefits.color_scheme_label", "default": "scheme-4" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "t:sections.non_stop_benefits.block_name",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.non_stop_benefits.icon_label",
          "options": [
            { "value": "shipping", "label": "t:sections.non_stop_benefits.shipping_icon" },
            { "value": "returns", "label": "t:sections.non_stop_benefits.returns_icon" },
            { "value": "warranty", "label": "t:sections.non_stop_benefits.warranty_icon" },
            { "value": "suitcase", "label": "t:sections.non_stop_benefits.suitcase_icon" }
          ],
          "default": "shipping"
        },
        { "type": "text", "id": "title", "label": "t:sections.non_stop_benefits.title_label", "default": "t:sections.non_stop_benefits.title_default" },
        { "type": "richtext", "id": "text", "label": "t:sections.non_stop_benefits.text_label", "default": "t:sections.non_stop_benefits.text_default" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.non_stop_benefits.name",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit", "settings": { "icon": "returns", "title": "30-day returns", "text": "<p>Take the time to make sure the piece is right for you.</p>" } },
        { "type": "benefit", "settings": { "icon": "warranty", "title": "3-year warranty", "text": "<p>Travel with coverage against manufacturing defects.</p>" } }
      ]
    }
  ]
}
{% endschema %}
