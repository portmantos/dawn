{%- assign selected_variant = product.selected_or_first_available_variant -%}

<media-gallery
  id="MediaGallery-{{ section.id }}"
  class="non-stop-gallery"
  role="region"
  aria-label="{{ 'products.product.media.gallery_viewer' | t }}"
  data-non-stop-gallery
>
  <a class="skip-to-content-link button visually-hidden quick-add-hidden" href="#ProductInfo-{{ section.id }}">
    {{ 'accessibility.skip_to_product_info' | t }}
  </a>
  <div class="non-stop-gallery__stage">
    {%- for variant in product.variants -%}
      {%- assign variant_gallery = variant.metafields.custom.variant_gallery.value -%}
      {%- assign fallback_image = variant.featured_media.preview_image | default: product.media.first.preview_image -%}
      <div
        class="non-stop-gallery__variant{% unless variant.id == selected_variant.id %} hidden{% endunless %}"
        data-variant-gallery="{{ variant.id }}"
      >
        {%- if variant_gallery != blank -%}
          {%- assign primary_image = variant_gallery | first -%}
          {%- assign primary_alt = primary_image.alt | default: product.title -%}
          <button class="non-stop-gallery__main" type="button" aria-label="{{ 'products.product.media.open_media' | t }}">
            {{ primary_image | image_url: width: 1800 | image_tag: class: 'non-stop-gallery__main-image', loading: 'eager', alt: primary_alt }}
          </button>
          <div class="non-stop-gallery__thumbs" role="list">
            {%- for image in variant_gallery -%}
              {%- assign image_alt = image.alt | default: product.title -%}
              <button
                type="button"
                class="non-stop-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                data-gallery-image="{{ image | image_url: width: 1800 }}"
                data-gallery-alt="{{ image_alt | escape }}"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }}"
              >
                {{ image | image_url: width: 180 | image_tag: loading: 'lazy', alt: image_alt }}
              </button>
            {%- endfor -%}
          </div>
        {%- elsif fallback_image != blank -%}
          <button class="non-stop-gallery__main" type="button" aria-label="{{ 'products.product.media.open_media' | t }}">
            {{ fallback_image | image_url: width: 1800 | image_tag: class: 'non-stop-gallery__main-image', loading: 'eager', alt: product.title }}
          </button>
          <div class="non-stop-gallery__thumbs" role="list">
            <button
              type="button"
              class="non-stop-gallery__thumb is-active"
              data-gallery-image="{{ fallback_image | image_url: width: 1800 }}"
              data-gallery-alt="{{ product.title | escape }}"
              aria-label="{{ 'sections.slideshow.load_slide' | t }} 1"
            >
              {{ fallback_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: product.title }}
            </button>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</media-gallery>
